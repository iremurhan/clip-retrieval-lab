#!/bin/bash
# =============================================================================
# Clean a legacy caption_rewrites_<model>.json that was generated by an old
# generate_rewrites.py path which padded with the original caption. This
# normalizes each rewrites list and emits a derived .failed.jsonl for the
# retry pass. Use only on legacy outputs (Flickr30k pre-patch); the patched
# generator does not produce padded entries.
#
# Positional args:
#   $1  DATASET     "coco" or "flickr30k"
#   $2  MODEL_SLUG  e.g. "meta-llama-3-8b-instruct"
#
# Examples:
#   sbatch scripts/setup/clean_canonical_rewrites.slurm flickr30k meta-llama-3-8b-instruct
#   sbatch scripts/setup/clean_canonical_rewrites.slurm flickr30k mistral-7b-instruct-v0.2
#
# Modifies: ${DATASET_DIR}/caption_rewrites_${MODEL_SLUG}.json (in place)
# Writes:   ${DATASET_DIR}/caption_rewrites_${MODEL_SLUG}.failed.jsonl
# =============================================================================
#SBATCH --time=00:15:00
#SBATCH --gpus=1
#SBATCH --cpus-per-gpu=4
#SBATCH --mem-per-gpu=48G
#SBATCH --container-image=biremurhan/image-text-contrast:v0.16
#SBATCH --container-mounts=/users/beyza.urhan/clip-retrieval-lab:/workspace,/users/beyza.urhan/experiments/datasets/coco:/workspace/datasets/coco,/users/beyza.urhan/experiments/datasets/flickr30k:/workspace/datasets/flickr30k
#SBATCH --output=/users/beyza.urhan/experiments/results/slurm_%j_clean.out
#SBATCH --error=/users/beyza.urhan/experiments/results/slurm_%j_clean.out
#SBATCH --container-env=PYTHONPATH=/workspace

set -euo pipefail

DATASET="${1:?Usage: sbatch <script> <coco|flickr30k> <model_slug>}"
MODEL_SLUG="${2:?Usage: sbatch <script> <dataset> <model_slug>}"

case "$DATASET" in
    coco)
        KARPATHY="/workspace/datasets/coco/caption_datasets/dataset_coco.json"
        DATASET_DIR="/workspace/datasets/coco"
        ;;
    flickr30k)
        KARPATHY="/workspace/datasets/flickr30k/caption_datasets/dataset_flickr30k.json"
        DATASET_DIR="/workspace/datasets/flickr30k"
        ;;
    *) echo "Unknown dataset: $DATASET"; exit 1 ;;
esac

CANONICAL="${DATASET_DIR}/caption_rewrites_${MODEL_SLUG}.json"
FAILED_OUT="${DATASET_DIR}/caption_rewrites_${MODEL_SLUG}.failed.jsonl"

for f in "$KARPATHY" "$CANONICAL"; do
    if [ ! -f "$f" ]; then
        echo "ERROR: file not found: $f"
        exit 1
    fi
done

echo "=========================================="
echo "Job ID:     ${SLURM_JOB_ID}"
echo "Karpathy:   ${KARPATHY}"
echo "Canonical:  ${CANONICAL}"
echo "Failed out: ${FAILED_OUT}"
echo "=========================================="

cd /workspace
python3 -u tools/clean_canonical_rewrites.py \
    --karpathy "$KARPATHY" \
    --canonical "$CANONICAL" \
    --failed_out "$FAILED_OUT" \
    --num_rewrites 2

echo ""
echo "=========================================="
echo "Clean complete. Next: run retry pass."
echo "  sbatch legacy/paraphrase_generation/retry_failed_rewrites.slurm \\"
echo "      ${DATASET} <hf_model_id_matching_${MODEL_SLUG}>"
echo "=========================================="
